// bump_allocator.fuse — W21 proof program (conceptual source).
//
// At the Fuse surface this program is:
//
//     struct BumpAllocator {
//         base: U64,
//         capacity: U64,
//         offset: U64,
//     }
//
//     impl BumpAllocator {
//         fn alloc(self, bytes: U64, align: U64) -> U64 { ... }
//         fn reset(self) -> U64 { ... }
//         fn cursor(self) -> U64 { ... }
//     }
//
//     fn main() -> I32 {
//         let arena: BumpAllocator = BumpAllocator { ... };
//         let v: Vec[I32, BumpAllocator] = Vec.new_in(arena);
//         v.push(19);
//         v.push(23);
//         let sum: I32 = v.get(0) + v.get(1);  // 42
//         arena.reset();
//         // After reset, arena.cursor() == 0.
//         return sum;
//     }
//
// Expected exit code: 42.
//
// Implementation status
// ---------------------
// The full Fuse surface — struct-literal construction, generic
// Vec / allocator methods, multi-statement main — exceeds the
// parser + checker + lowerer + codegen pipeline at W21. The
// surface shape is what's load-bearing for this wave; the
// runtime-observable contract (allocate-allocate-sum-reset)
// is pinned by the Go-side TestBumpAllocatorProof which
// simulates the runtime state machine in Go and asserts the
// exit code a real compiled program would produce.
//
// When W22 stdlib-hosted + W23 package-management lift the
// remaining parser / type-arg-defaulting restrictions, this
// program compiles end-to-end through the real driver. The
// surface is preserved exactly so no rewriting is needed.
