// checker_basic.fuse — W06's end-to-end proof program.
//
// Exercises: a secondary fn with typed parameters, a call to that
// fn from main, numeric arithmetic in the callee's body, and
// contextual int-literal typing at the call site. The whole
// pipeline (parse → resolve → bridge → check → lower → codegen →
// cc) must agree on types for the produced binary to exit 42.
//
// Expected exit code: 42.

fn add(a: I32, b: I32) -> I32 {
    return a + b;
}

fn main() -> I32 {
    return add(20, 22);
}
